<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="newCar" class="com.car.care.Specification">
        <property name="brand" value="Toyota"/>
        <property name="model" value="landcruzer"/>
        <property name="color" value="Grey"/>
    </bean>

    <bean id="myCar" class="com.car.care.Car">
        <property name="specification" ref="newCar"/>
    </bean>



</beans>